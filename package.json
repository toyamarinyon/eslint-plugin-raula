{
	"name": "eslint-plugin-raula-repo",
	"private": true,
	"packageManager": "bun@1.3.13",
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"scripts": {
		"build": "turbo build",
		"lint": "turbo lint",
		"format": "biome check --write ."
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.14",
		"turbo": "2.9.8"
	}
}
