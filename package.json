{
	"name": "eslint-plugin-raula-repo",
	"private": true,
	"packageManager": "bun@1.3.13",
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"scripts": {
		"build": "turbo build --filter=!./apps/*",
		"lint": "turbo lint --filter=!./apps/*",
		"format": "biome check --write .",
		"format:check": "biome check .",
		"test": "bun test apps",
		"test:no-css-modules": "bun test apps/no-css-modules-fixture"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.14",
		"turbo": "2.9.8"
	}
}
